{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ryvern",
  "version": "0.1.0",
  "identifier": "com.local.ryvern",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ryvern",
        "width": 320,
        "height": 320,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
